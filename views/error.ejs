<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Title }} - {{ .AppName }}</title>
    <link rel="stylesheet" href="/css/style.css" id="theme-style">
  </head>
  <body class="error-page">
    <div class="error-card">
      <div class="error-code">{{ .StatusCode }}</div>
      <h1 class="error-title">{{ .Title }}</h1>
      <p class="error-message">{{ .Message }}</p>
      <div class="error-actions">
        {{ if and .ActionHref .ActionText }}
          <a class="error-button" href="{{ .ActionHref }}">{{ .ActionText }}</a>
        {{ end }}
        {{ if and .SecondaryHref .SecondaryText }}
          <a class="error-link" href="{{ .SecondaryHref }}">{{ .SecondaryText }}</a>
        {{ end }}
      </div>
    </div>
  </body>
</html>
