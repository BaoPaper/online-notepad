<!DOCTYPE html>
<html lang="zh">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= currentTitle %> - 在线记事本</title>
  <link rel="stylesheet" href="/css/style.css" id="theme-style">
  <script src="/js/marked.min.js"></script>
</head>

<body>
  <div class="app-container">
    <!-- 侧边栏遮罩 -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- 侧边栏 -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <button class="new-note-btn" id="new-note-btn">+ 新建笔记</button>
      </div>
      <div class="note-list" id="note-list">
        <% notes.forEach(function(n) { %>
          <div class="note-item <%= n.id === currentId ? 'active' : '' %>" data-id="<%= n.id %>">
            <a href="/note/<%= n.id %>" class="note-link"><%= n.title %></a>
            <button class="delete-btn" data-id="<%= n.id %>" title="删除">×</button>
          </div>
        <% }); %>
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="main-content">
      <div class="toolbar">
        <button class="menu-toggle-btn" id="menu-toggle">☰</button>
        <input type="text" class="title-input" id="title-input" value="<%= currentTitle %>" placeholder="笔记标题">
        <div class="toolbar-actions">
          <label class="upload-btn" title="上传附件">
            <input type="file" id="file-input" hidden>
            📎
          </label>
          <button id="toggle-view" title="切换视图">预览</button>
        </div>
      </div>
      <div class="editor-container" id="editor-container">
        <textarea name="note" id="editor" spellcheck="false"><%= note %></textarea>
        <div id="preview" class="preview-pane"></div>
      </div>
    </main>
  </div>

  <script>
    (function() {
      var currentId = '<%= currentId %>';
      var editor = document.getElementById('editor');
      var preview = document.getElementById('preview');
      var editorContainer = document.getElementById('editor-container');
      var toggleViewBtn = document.getElementById('toggle-view');
      var titleInput = document.getElementById('title-input');
      var sidebar = document.getElementById('sidebar');
      var sidebarOverlay = document.getElementById('sidebar-overlay');
      var menuToggle = document.getElementById('menu-toggle');
      var newNoteBtn = document.getElementById('new-note-btn');
      var fileInput = document.getElementById('file-input');

      // 渲染 Markdown
      function renderMarkdown() {
        preview.innerHTML = marked.parse(editor.value);
      }
      renderMarkdown();

      // 防抖
      function debounce(func, wait) {
        var timeout;
        return function() {
          clearTimeout(timeout);
          timeout = setTimeout(function() { func(); }, wait);
        };
      }

      // 保存内容
      function saveContent() {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/save/' + currentId);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.send('note=' + encodeURIComponent(editor.value));
      }

      // 保存标题
      var saveTitle = debounce(function() {
        var xhr = new XMLHttpRequest();
        xhr.open('PUT', '/api/notes/' + currentId + '/title');
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          if (xhr.status === 200) {
            var res = JSON.parse(xhr.responseText);
            document.title = res.title + ' - 在线记事本';
            var item = document.querySelector('.note-item[data-id="' + currentId + '"] .note-link');
            if (item) item.textContent = res.title;
          }
        };
        xhr.send(JSON.stringify({ title: titleInput.value }));
      }, 500);

      // 编辑器输入
      editor.addEventListener('input', debounce(function() {
        renderMarkdown();
        saveContent();
      }, 300));

      // 标题输入
      titleInput.addEventListener('input', saveTitle);

      // Ctrl+S 保存
      document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && (e.key === 's' || e.key === 'S')) {
          e.preventDefault();
          saveContent();
        }
      });

      // 视图切换
      function checkMobileView() {
        if (window.innerWidth <= 768) {
          editorContainer.classList.add('editor-only');
          sidebar.classList.remove('open');
        } else {
          editorContainer.classList.remove('editor-only', 'preview-only');
        }
      }
      checkMobileView();
      window.addEventListener('resize', checkMobileView);

      toggleViewBtn.addEventListener('click', function() {
        if (editorContainer.classList.contains('editor-only')) {
          editorContainer.classList.remove('editor-only');
          editorContainer.classList.add('preview-only');
          toggleViewBtn.textContent = '编辑';
        } else if (editorContainer.classList.contains('preview-only')) {
          editorContainer.classList.remove('preview-only');
          toggleViewBtn.textContent = '预览';
        } else {
          editorContainer.classList.add('editor-only');
          toggleViewBtn.textContent = '预览';
        }
      });

      // 侧边栏切换（移动端）
      function closeSidebar() {
        sidebar.classList.remove('open');
        sidebarOverlay.classList.remove('open');
      }
      function openSidebar() {
        sidebar.classList.add('open');
        sidebarOverlay.classList.add('open');
      }
      menuToggle.addEventListener('click', function() {
        if (sidebar.classList.contains('open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });
      sidebarOverlay.addEventListener('click', closeSidebar);

      // 点击笔记链接后关闭侧边栏
      document.querySelectorAll('.note-link').forEach(function(link) {
        link.addEventListener('click', closeSidebar);
      });

      // 新建笔记
      newNoteBtn.addEventListener('click', function() {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/api/notes');
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          if (xhr.status === 200) {
            var note = JSON.parse(xhr.responseText);
            window.location.href = '/note/' + note.id;
          }
        };
        xhr.send(JSON.stringify({ title: '新建笔记' }));
      });

      // 删除笔记
      document.getElementById('note-list').addEventListener('click', function(e) {
        if (e.target.classList.contains('delete-btn')) {
          e.preventDefault();
          e.stopPropagation();
          var id = e.target.dataset.id;
          if (!confirm('确定删除这个笔记吗？')) return;

          var xhr = new XMLHttpRequest();
          xhr.open('DELETE', '/api/notes/' + id);
          xhr.onload = function() {
            if (xhr.status === 200) {
              if (id === currentId) {
                window.location.href = '/';
              } else {
                e.target.parentElement.remove();
              }
            }
          };
          xhr.send();
        }
      });

      // 文件上传
      fileInput.addEventListener('change', function() {
        var file = fileInput.files[0];
        if (!file) return;

        if (file.size > 10 * 1024 * 1024) {
          alert('文件大小不能超过 10MB');
          fileInput.value = '';
          return;
        }

        var formData = new FormData();
        formData.append('file', file);
        formData.append('noteId', currentId);

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/api/upload');
        xhr.onload = function() {
          if (xhr.status === 200) {
            var res = JSON.parse(xhr.responseText);
            // 在光标位置插入 markdown
            var start = editor.selectionStart;
            var end = editor.selectionEnd;
            var text = editor.value;
            editor.value = text.substring(0, start) + res.markdown + text.substring(end);
            editor.selectionStart = editor.selectionEnd = start + res.markdown.length;
            editor.focus();
            renderMarkdown();
            saveContent();
          } else {
            alert('上传失败');
          }
        };
        xhr.send(formData);
        fileInput.value = '';
      });
    })();
  </script>
</body>

</html>
